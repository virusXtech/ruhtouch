---
import { therapyTopics, faqs } from '../data/seoContent';
---

<section class="py-16 bg-white border-t border-emerald-50" id="therapy">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center max-w-3xl mx-auto mb-16" data-aos="fade-up">
      <h2 class="text-3xl font-arabic text-emerald-900 mb-6">
        Online Therapy Focus Areas
      </h2>
      <p class="text-gray-600 text-lg leading-relaxed">
        RuhTouch provides specialized online counseling for emotional
        well-being, relationships, and mental health—all from the comfort of a
        private, remote setting.
      </p>
    </div>

    <!-- Therapy Topics Grid matching Services vibes -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-20">
      {
        therapyTopics.map((topic, index) => (
          <div
            class="bg-emerald-50 rounded-lg p-8 hover:shadow-lg transition-all hover:-translate-y-1 cursor-pointer"
            data-aos="fade-up"
            data-aos-delay={index * 100}
          >
            <h3 class="text-xl font-semibold text-emerald-800 mb-4">
              {topic.title}
            </h3>
            <p class="text-gray-600 leading-relaxed">{topic.description}</p>
          </div>
        ))
      }
    </div>

    <!-- Simple, Clean FAQ Section -->
    <div class="max-w-4xl mx-auto" data-aos="fade-up" data-aos-delay="200">
      <h2 class="text-3xl font-arabic text-center text-emerald-900 mb-10">
        Frequently Asked Questions
      </h2>
      <div class="space-y-4">
        {
          faqs.map(faq => (
            <details class="group bg-white border border-emerald-100 rounded-lg open:border-emerald-300 open:shadow-sm transition-all duration-200">
              <summary class="flex cursor-pointer items-center justify-between p-6 font-semibold text-emerald-900 marker:content-none transition-colors group-hover:text-emerald-700">
                {faq.question}
                <span class="transition-transform duration-300 group-open:rotate-180 text-emerald-600">
                  <svg
                    fill="none"
                    height="24"
                    stroke="currentColor"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    viewBox="0 0 24 24"
                    width="24"
                  >
                    <path d="M6 9l6 6 6-6" />
                  </svg>
                </span>
              </summary>
              <div class="px-6 pb-6 text-gray-600 leading-relaxed border-t border-emerald-50 pt-4 mt-2">
                <p>{faq.answer}</p>
              </div>
            </details>
          ))
        }
      </div>
    </div>
  </div>
</section>
