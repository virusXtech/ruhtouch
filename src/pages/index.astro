---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import Services from '../components/Services.astro';
import TherapyTopics from '../components/TherapyTopics.astro';
import About from '../components/About.astro';
import Testimonials from '../components/Testimonials.astro';
import Contact from '../components/Contact.astro';
import Footer from '../components/Footer.astro';
import services from '../data/services';
import { faqs } from '../data/seoContent';
import siteConfig from '../data/site';

const pageTitle =
  'Online Therapy, Counseling, and Therapist Support | RuhTouch';
const pageDescription =
  'RuhTouch provides online therapy and remote counseling with support for anxiety, stress, relationships, family concerns, youth, crisis intervention, and couples counseling.';

const structuredData = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'WebSite',
      '@id': `${siteConfig.siteUrl}/#website`,
      url: `${siteConfig.siteUrl}/`,
      name: siteConfig.name,
      description: pageDescription,
      inLanguage: 'en-IN',
    },
    {
      '@type': 'ProfessionalService',
      '@id': `${siteConfig.siteUrl}/#organization`,
      name: siteConfig.name,
      image: siteConfig.heroImage,
      url: `${siteConfig.siteUrl}/`,
      telephone: siteConfig.phone,
      email: siteConfig.email,
      areaServed: siteConfig.serviceArea,
      availableChannel: {
        '@type': 'ServiceChannel',
        serviceUrl: `${siteConfig.siteUrl}/#contact`,
        availableLanguage: 'en',
      },
      description: pageDescription,
      priceRange: '$$',
      knowsAbout: services.map(service => service.title),
      serviceType: services.map(service => service.title),
    },
    {
      '@type': 'FAQPage',
      '@id': `${siteConfig.siteUrl}/#faq`,
      mainEntity: faqs.map(faq => ({
        '@type': 'Question',
        name: faq.question,
        acceptedAnswer: {
          '@type': 'Answer',
          text: faq.answer,
        },
      })),
    },
  ],
};
---

<Layout title={pageTitle} description={pageDescription} canonicalPath="/">
  <script
    type="application/ld+json"
    set:html={JSON.stringify(structuredData)}
  />
  <Header />
  <main>
    <Hero />
    <Services />
    <TherapyTopics />
    <About />
    <Testimonials />
    <Contact />
  </main>
  <Footer />
</Layout>
